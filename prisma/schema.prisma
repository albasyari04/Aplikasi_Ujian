// prisma/schema.prisma
//
// ✅ ROOT CAUSE #4 LOADING LAMBAT — INI YANG PALING BERDAMPAK:
// Schema sebelumnya TIDAK PUNYA INDEX sama sekali selain @id dan @unique.
//
// Ini berarti SETIAP query yang filter berdasarkan ujianId, userId, status,
// dll melakukan FULL TABLE SCAN — database baca semua baris satu per satu.
//
// Contoh query yang slow tanpa index:
//   prisma.soal.findMany({ where: { ujianId: "..." } })
//   → MySQL scan semua baris di tabel Soal untuk cari yang ujianId cocok
//
//   prisma.hasilUjian.findMany({ where: { userId: "...", ujianId: "..." } })
//   → MySQL scan semua baris HasilUjian
//
// Dengan index, query ini turun dari O(n) → O(log n).
// Untuk 200 soal perbedaannya kecil, tapi untuk 10.000+ soal = 100x lebih cepat.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  nama       String
  email      String   @unique
  password   String
  role       Role     @default(SISWA)
  nis        String?
  kelas      String?
  fotoProfil String?
  createdAt  DateTime @default(now())

  jawaban    Jawaban[]
  hasilUjian HasilUjian[]

  // ✅ FIX: Index untuk filter by role (dashboard admin: ambil semua SISWA)
  // dan filter by kelas (ujian per kelas)
  @@index([role])
  @@index([kelas])
  @@index([role, kelas]) // Composite: ambil siswa kelas X
}

model Ujian {
  id           String      @id @default(cuid())
  judul        String
  mapel        String
  guru         String
  kelas        String
  status       StatusUjian @default(DRAFT)
  tanggal      DateTime
  waktuMulai   DateTime
  waktuSelesai DateTime
  durasi       Int
  createdAt    DateTime    @default(now())

  soal         Soal[]
  hasil        HasilUjian[]

  // ✅ FIX: Index untuk query paling sering:
  // - Filter by status (siswa: ambil ujian AKTIF)
  // - Filter by kelas (ujian untuk kelas XII IPA 1)
  // - Filter by tanggal (jadwal hari ini)
  // - Composite status+kelas (query utama dashboard siswa)
  @@index([status])
  @@index([kelas])
  @@index([tanggal])
  @@index([status, kelas])       // Ujian AKTIF untuk kelas tertentu
  @@index([status, waktuMulai])  // Ujian berlangsung sekarang
  @@index([createdAt])           // Sort by terbaru
}

model Soal {
  id           String    @id @default(cuid())
  ujianId      String
  nomor        Int
  pertanyaan   String    @db.Text
  tipe         TipeSoal  @default(PILIHAN_GANDA)
  opsiA        String?
  opsiB        String?
  opsiC        String?
  opsiD        String?
  opsiE        String?
  kunciJawaban String?
  bobot        Int       @default(1)

  ujian        Ujian     @relation(fields: [ujianId], references: [id], onDelete: Cascade)
  jawaban      Jawaban[]

  // ✅ FIX: Index PALING PENTING — hampir semua query Soal filter by ujianId
  // Tanpa ini: setiap halaman ujian scan seluruh tabel Soal
  @@index([ujianId])
  @@index([ujianId, nomor])  // Composite: ambil soal ujian X urut nomor
  @@index([tipe])            // Filter by tipe (statistik PG vs Essay)
}

model Jawaban {
  id      String @id @default(cuid())
  userId  String
  soalId  String
  jawaban String

  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  soal    Soal   @relation(fields: [soalId], references: [id], onDelete: Cascade)

  @@unique([userId, soalId])

  // ✅ FIX: Index untuk query progress siswa & rekap jawaban
  @@index([userId])
  @@index([soalId])
  @@index([userId, soalId]) // Sudah di-cover @@unique, tapi eksplisit lebih baik
}

model HasilUjian {
  id        String   @id @default(cuid())
  userId    String
  ujianId   String
  nilai     Float
  lulus     Boolean
  selesaiAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ujian     Ujian    @relation(fields: [ujianId], references: [id], onDelete: Cascade)

  // ✅ FIX: Index untuk query riwayat ujian siswa & rekap hasil
  @@index([userId])
  @@index([ujianId])
  @@index([userId, ujianId])  // Cek apakah siswa sudah mengerjakan ujian ini
  @@index([lulus])            // Filter statistik kelulusan
  @@index([selesaiAt])        // Sort by terbaru
  @@index([ujianId, lulus])   // Statistik kelulusan per ujian
}

enum Role {
  SISWA
  GURU
  ADMIN
}

enum TipeSoal {
  PILIHAN_GANDA
  ESSAY
}

// ✅ BARU: status ujian untuk kontrol publish
enum StatusUjian {
  DRAFT
  AKTIF
  SELESAI
}
